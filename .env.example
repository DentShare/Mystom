# MiniStom Bot — пример конфигурации
# Скопируйте в .env и заполните значения. Файл .env не коммитить в репозиторий!

# Токен бота от @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# PostgreSQL (asyncpg). На сервере укажите хост/пароль вашей БД
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ministom

# Telegram ID администраторов через запятую (узнать: @userinfobot)
ADMIN_IDS=123456789,987654321

# URL веб-админки (HTTPS). Если пусто — кнопка Web App в /admin не показывается
ADMIN_WEBAPP_URL=

# OpenAI API Key (для голосовой записи: Whisper + GPT-4o-mini)
OPENAI_API_KEY=sk-your-openai-key-here

# Опционально: ключ для автоопределения часового пояса по координатам
TIMEZONE_API_KEY=optional_for_auto_detect

# Оплата подписки (переводом на карту)
PAYMENT_CARD=
PAYMENT_RECEIVER=
ADMIN_CONTACT=@your_username
SUBSCRIPTION_STANDARD_PRICE=по запросу
SUBSCRIPTION_PREMIUM_PRICE=по запросу
